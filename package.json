{
  "name": "shotmob-event-engine",
  "version": "1.0.0",
  "description": "Real-time sports event engine with TypeScript, PostgreSQL, pgvector, Redis, BullMQ, Socket.IO and OpenAI.",
  "main": "dist/server.js",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker:event": "tsx watch src/workers/event.worker.ts",
    "dev:worker:video": "tsx watch src/workers/video.worker.ts",
    "dev": "concurrently -n api,event-worker,video-worker -c blue,green,magenta \"npm:dev:api\" \"npm:dev:worker:event\" \"npm:dev:worker:video\"",
    "migrate": "tsx src/db/migrate.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker:event": "node dist/workers/event.worker.js",
    "worker:video": "node dist/workers/video.worker.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "latest",
    "bcryptjs": "latest",
    "bullmq": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "latest",
    "openai": "latest",
    "pg": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "socket.io": "latest",
    "uuid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}

{
  "name": "shotmob-event-engine",
  "version": "1.0.0",
  "description": "Real-time sports event engine with TypeScript, PostgreSQL, pgvector, Redis, BullMQ, Socket.IO and OpenAI.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:event-worker\" \"npm:dev:video-worker\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:event-worker": "tsx watch src/workers/event.worker.ts",
    "dev:video-worker": "tsx watch src/workers/video.worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:api": "node dist/server.js",
    "start:event-worker": "node dist/workers/event.worker.js",
    "start:video-worker": "node dist/workers/video.worker.js",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "latest",
    "bcryptjs": "latest",
    "bullmq": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "latest",
    "openai": "latest",
    "pg": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "socket.io": "latest",
    "uuid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}